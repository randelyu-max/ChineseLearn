digraph G {
  rankdir=LR;
  graph [fontname="Noto Sans CJK SC", nodesep=0.45, ranksep=0.7, pad=0.25];
  node [shape=box, style="rounded", fontname="Noto Sans CJK SC", fontsize=10];
  edge [fontname="Noto Sans CJK SC", fontsize=9];
  constraints [label="确定性约束\n已学汉字、词汇、年龄、兴趣"];
  pii [label="去标识化\n不含姓名、学校、地址"];
  inmod [label="输入审核"];
  gen [label="结构化生成\nJSON Schema"];
  validate [label="确定性验证\n字表、长度、语法、题目答案"];
  outmod [label="输出审核"];
  cache [label="缓存/人工抽检\n再交付儿童端"];
  constraints -> pii -> inmod -> gen -> validate -> outmod -> cache;
  validate -> gen [label="失败时有限重试", constraint=false];
}
