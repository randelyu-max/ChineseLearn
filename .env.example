# Mobile-safe public API origin.
EXPO_PUBLIC_API_URL=http://127.0.0.1:3001

# Server-only configuration. Generate real secrets outside source control.
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://127.0.0.1:3001
# Local testing only. Production rejects false and requires SMTP.
AUTH_REQUIRE_EMAIL_VERIFICATION=false
APP_ORIGINS=hanziquest://,http://localhost:8081,http://localhost:3000
HOST=0.0.0.0
PORT=3001

# Transactional email transport. Required for registration verification and password recovery.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
