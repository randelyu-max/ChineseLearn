{
  "name": "@hanziquest/content-validator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:content": "node --experimental-strip-types src/cli.ts"
  },
  "dependencies": {
    "@hanziquest/contracts": "workspace:*",
    "@hanziquest/curriculum": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.13.3"
  }
}
